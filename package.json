{
  "name": "st-resource-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SillyTavern resource manager with Vault for Termux private storage.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "node scripts/build-client.mjs",
    "build:client:vite": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "start:quick": "bash scripts/start-quick.sh",
    "test": "npm run build:server && cross-env ST_MANAGER_HOME=.test-data node dist/server/tests/run-tests.js"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.3.0",
    "@uiw/react-codemirror": "^4.25.2",
    "fastify": "^5.6.1",
    "fs-extra": "^11.3.2",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "simple-git": "^3.30.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@types/fs-extra": "^11.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
